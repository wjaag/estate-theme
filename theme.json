{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1440px"
    },
    "color": {
      "palette": [
        {
          "slug": "primary",
          "color": "#1B6EF3",
          "name": "Primary"
        },
        {
          "slug": "secondary",
          "color": "#111827",
          "name": "Secondary"
        },
        {
          "slug": "accent",
          "color": "#F59E0B",
          "name": "Accent"
        },
        {
          "slug": "background",
          "color": "#FFFFFF",
          "name": "Background"
        },
        {
          "slug": "surface",
          "color": "#F7F8FA",
          "name": "Surface"
        },
        {
          "slug": "text",
          "color": "#111827",
          "name": "Text"
        }
      ]
    },
    "spacing": {
      "units": [
        "px",
        "rem",
        "%"
      ]
    },
    "typography": {
      "fluid": true
    }
  }
}